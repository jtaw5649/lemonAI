{
  "name": "lemonai",
  "version": "1.0.0",
  "description": "lemonAI Discord chat and image bot powered by OpenRouter and Pollinations.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "deploy:commands": "tsx src/deploy-commands.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "openai": "^6.44.0"
  },
  "overrides": {
    "undici": "^7.16.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
