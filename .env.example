# Discord application credentials.
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# Set for instant guild command updates while developing. Leave empty for global commands.
DISCORD_GUILD_ID=

# OpenRouter free-model chat API.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/free
OPENROUTER_FALLBACK_MODELS=cognitivecomputations/dolphin-mistral-24b-venice-edition:free,meta-llama/llama-3.3-70b-instruct:free,qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_VISION_MODEL=nvidia/nemotron-nano-12b-v2-vl:free
OPENROUTER_VISION_FALLBACK_MODELS=nex-agi/nex-n2-pro:free,google/gemma-4-31b-it:free
OPENROUTER_SITE_URL=https://discord.com
OPENROUTER_APP_NAME=lemonAI

# OpenCode Go chat API. Used before OpenRouter when OPENCODE_GO_API_KEY is set.
OPENCODE_GO_API_KEY=
OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1
OPENCODE_GO_MODEL=mimo-v2.5-pro
OPENCODE_GO_FALLBACK_MODELS=qwen3.7-plus,minimax-m3,glm-5.2
OPENCODE_GO_VISION_MODEL=
OPENCODE_GO_VISION_FALLBACK_MODELS=

# Pollinations image API. Token is optional; anonymous mode is slower and watermarked.
POLLINATIONS_TOKEN=
POLLINATIONS_USE_TOKEN=false
POLLINATIONS_NOLOGO=false
POLLINATIONS_IMAGE_BASE_URL=https://image.pollinations.ai/prompt
POLLINATIONS_IMAGE_MODEL=turbo

# Bot behavior.
BOT_NAME=lemonAI
AUTO_REPLY_ENABLED=true
ALLOWED_CHANNEL_IDS=
IGNORED_CHANNEL_IDS=
MEMORY_PATH=./data/memory.json
MAX_HISTORY_MESSAGES=24
MAX_RESPONSE_CHARS=1800

# Chat controls.
CHAT_TEMPERATURE=1.35
CHAT_MAX_TOKENS=650
USER_COOLDOWN_MS=6000
CHANNEL_COOLDOWN_MS=2500

# Image controls.
IMAGE_COOLDOWN_MS=30000
IMAGE_ASPECT_RATIO=1:1
IMAGE_WIDTH=768
IMAGE_HEIGHT=768
IMAGE_TIMEOUT_MS=120000

# Autopost scheduling: jitter avoids robotic exact intervals; max late avoids catch-up spam after downtime.
AUTO_POST_JITTER_PERCENT=20
AUTO_POST_MAX_LATE_MS=300000

# debug, info, warn, error
LOG_LEVEL=info
